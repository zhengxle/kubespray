# Ansible Managed: Chrony configuration for NTP client

# Use assigned NTP servers
{% if (ntp.local | default([])) %}
{% for server in ntp.local %}
pool {{ server }} iburst maxsources 2
{% endfor %}
{% else %}
{% for server in ntp.remote %}
pool {{ server }} iburst maxsources 2
{% endfor %}
{% endif%}

# Record the rate at which the system clock gains/losses time
driftfile /var/lib/chrony/chrony.drift

# Directory for log files
logdir /var/log/chrony

# Save clock updates on system shutdown
dumponexit

# Specify directory for dump files
dumpdir /var/lib/chrony

# Key file for NTP authentication
keyfile /etc/chrony/chrony.keys

# Command key for chronyc
commandkey 1

# Generate command key if missing
generatecommandkey

# Disable logging of client accesses
noclientlog

# RTCDEVICE
rtcdevice /dev/rtc0

# Makestep
makestep 1.0 3